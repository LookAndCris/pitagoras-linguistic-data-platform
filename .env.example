PITAGORAS_DB_HOST=postgres.example.internal
PITAGORAS_DB_PORT=5432
PITAGORAS_DB_NAME=pitagoras
PITAGORAS_DB_USER=pitagoras
PITAGORAS_DB_PASSWORD=replace-me
PITAGORAS_DB_SSLMODE=require
PITAGORAS_DB_POOL_SIZE=5
PITAGORAS_DB_MAX_OVERFLOW=10
PITAGORAS_DB_POOL_RECYCLE_SECONDS=1800

# Optional local PostgreSQL overlay defaults (used by docker-compose.postgres.yml)
PITAGORAS_LOCAL_DB_NAME=pitagoras
PITAGORAS_LOCAL_DB_USER=pitagoras
PITAGORAS_LOCAL_DB_PASSWORD=pitagoras
PITAGORAS_LOCAL_DB_PORT=55432
